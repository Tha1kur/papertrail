# Copy to .env and fill in. The server refuses to boot if anything here is
# missing or malformed — see src/config/env.ts for the schema.

# development | test | production
NODE_ENV=development

PORT=8080

# MongoDB Atlas M0 (free): https://mongodb.com/cloud/atlas
# Atlas gives you this under "Connect" -> "Drivers".
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/papertrail

# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=debug

# Comma-separated allowlist. Never "*" — this API uses credentialed cookies
# and browsers reject a wildcard origin on those.
CORS_ORIGINS=http://localhost:5173

# How long in-flight requests get to finish during a deploy.
SHUTDOWN_TIMEOUT_MS=10000

# --- Language models ---
# Both providers have free tiers that need no card.

# Primary. Also supplies embeddings, which retrieval depends on.
# Key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001

# Must match the Atlas vector index, and cannot change after documents are
# indexed without recomputing every stored vector.
GEMINI_EMBED_DIMENSIONS=768

# 0 disables the model's internal reasoning pass — faster first token, fewer
# output tokens spent. Raise if multi-step answers get weak.
GEMINI_THINKING_BUDGET=0

# Failover for chat only — Groq has no free embeddings endpoint.
# Key: https://console.groq.com
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Per-call ceiling before we give up and try the fallback provider.
LLM_TIMEOUT_MS=60000

# --- Conversation context ---
# Input tokens for system prompt + history. Well below the model's real
# context window: tokens are latency and quota, not just a hard limit.
# Older turns beyond this are summarised rather than dropped.
CONTEXT_BUDGET_TOKENS=8000

# Comment frame sent on an idle SSE stream so proxies don't close it while
# the model is still thinking about the first token.
SSE_HEARTBEAT_MS=15000

# --- Authentication ---

# REQUIRED. Generate with:  openssl rand -base64 48
# Must be at least 32 characters. A short secret still verifies tokens
# perfectly well, so a weak one fails silently rather than loudly.
JWT_ACCESS_SECRET=

# Access tokens cannot be revoked individually, so their lifetime bounds the
# damage from a leaked one. The refresh token does the long-lived work.
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# bcrypt work factor. 12 is roughly 250ms — slow enough to make offline
# cracking expensive, fast enough that a login still feels instant.
BCRYPT_ROUNDS=12

# Only needed when the API and client sit on different subdomains in
# production. Leave blank for localhost and for cross-site deploys.
# COOKIE_DOMAIN=

# --- Retrieval ---
# The vector index is created by:  npm run ensure-index
# (idempotent, safe on every deploy)

# Passages retrieved per question. More is not better — each one spends
# context budget and makes the model hedge across sources.
RAG_TOP_K=6

# Share of the context budget reserved for retrieved passages.
RAG_CONTEXT_TOKENS=3000

# Minimum relevance score. NOTE the scale: Atlas reports cosine similarity
# rescaled to (1 + cos) / 2, so 0.5 means orthogonal, not zero. Measured on
# a sample corpus: on-topic ~0.88, off-topic ~0.75, so 0.80 sits in the gap.
RAG_MIN_SCORE=0.80

# Also drop passages scoring this far below the best match, so one strong
# result is not diluted by weaker ones that merely cleared the floor.
RAG_SCORE_DROPOFF=0.08

# Upload ceiling. Atlas M0 has 512MB total across every collection.
MAX_UPLOAD_BYTES=10485760

# --- Rate limiting and cost control ---

# Optional. Free tier at https://upstash.com — create a Redis database and
# copy the REST url and token from its dashboard.
#
# Without these the limiter falls back to in-memory, which counts per
# process. That is correct on a single instance and wrong the moment there
# are two: each keeps its own tally, so every allowance is multiplied by the
# instance count. Fine locally, a real gap in production.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Generous for a person typing, ruinous for a script draining the API quota.
RATE_LIMIT_CHAT_PER_MINUTE=12

# Uploads are the expensive path — one document can be hundreds of
# embedding calls — so the window is an hour.
RATE_LIMIT_UPLOAD_PER_HOUR=20

# Keyed on IP, since there is no user yet. Shared by login and register.
RATE_LIMIT_AUTH_PER_15MIN=20

# Total tokens one user may spend per day, resetting at UTC midnight.
# Rate limiting caps requests per minute; this caps total cost. They are
# different problems: 12 requests a minute sustained all day is still a
# very large bill.
DAILY_TOKEN_BUDGET=150000

# Chunk size measured with the eval harness (npm run eval), not guessed:
#
#   chars  chunks  passed  recall@6  MRR    refused by threshold
#   1200   2       14/15   91.7%     0.917  2/3
#   700    4       15/15   100%      0.917  2/3
#   450    6       15/15   100%      0.875  1/3
#
# Re-measure if your corpus changes character.
CHUNK_TARGET_CHARS=700
CHUNK_OVERLAP_CHARS=120
