# Install devDependencies even when NODE_ENV=production.
#
# Render sets NODE_ENV=production for the runtime, correctly. npm also reads
# NODE_ENV during install, so a plain `npm ci` there skips devDependencies —
# where typescript and every @types package lives — and the build dies with
# ~90 "cannot find type definitions" errors that look like a broken codebase
# rather than a missing flag.
#
# render.yaml passes --include=dev, but a service created from a blueprint
# stores its build command at creation time: editing render.yaml and hitting
# "Manual Deploy" reuses the stored command, so the flag never applies. This
# file makes the build correct regardless of which command the platform runs.
#
# IMPORTANT: this is listed in .dockerignore.
#
# An .npmrc `include` beats the `--omit=dev` CLI flag (verified — the flag
# loses). If Docker could see this file, the runtime stage's `npm ci
# --omit=dev` would silently ship the whole toolchain in the production
# image, defeating the multi-stage build. The Docker build stage does not
# need it anyway: it never sets NODE_ENV, so it installs everything already.
include=dev
